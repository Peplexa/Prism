# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional for local dev - defaults to SQLite)
# DATABASE_URL=postgres://prism:password@localhost:5432/prism
DB_PASSWORD=prism_dev_password

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Event Registry (newsapi.ai)
NEWSAPI_AI_KEY=your-event-registry-api-key
EVENT_REGISTRY_MIN_ARTICLES=5
EVENT_REGISTRY_FETCH_HOURS=24
EVENT_REGISTRY_LANG=eng

# LLM Backend: 'ollama' or 'deepseek'
LLM_BACKEND=deepseek

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# DeepSeek API (cloud)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# Evaluation
SEMANTIC_MODEL=all-MiniLM-L6-v2
DEFAULT_SIMILARITY_THRESHOLD=0.8
